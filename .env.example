# =============================================================================
# Moja Pomoć — Environment variables
# =============================================================================
# This file documents all env vars used by the project.
# COPY this file to `.env.local` (gitignored) for local dev.
# For PRODUCTION, set these in Netlify dashboard:
#   Site → Site configuration → Environment variables → Add variable
# Trigger a redeploy after adding/changing.
# =============================================================================

# GoatCounter analytics site code (the subdomain part).
# If your dashboard is at mojapomoc.goatcounter.com, set this to "mojapomoc".
# Leave empty / unset to disable analytics (DEV mode falls back to console.log).
# Get one free at: https://www.goatcounter.com/signup
VITE_GOATCOUNTER_CODE=

# =============================================================================
# Notes:
# - All client-side env vars MUST be prefixed with VITE_ (Vite security).
# - Server-side secrets DO NOT belong here — we have no backend in V1.
# - `.env.local` is gitignored by default. Never commit it.
# - For CI (GitHub Actions), set secrets at:
#     Repo → Settings → Secrets and variables → Actions → New secret
#   Then reference in .github/workflows/deploy.yml as ${{ secrets.NAME }}.
# =============================================================================
